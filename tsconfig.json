{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["src", "storybook/src/primitives", "storybook/src/agentic", "storybook/src/_shared", "storybook/src/foundations", "storybook/src/composites", "storybook/src/templates", "storybook/src/states", "storybook/src/kits"],
  "exclude": ["node_modules", "dist", "storybook/node_modules"]
}
